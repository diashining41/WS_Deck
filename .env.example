# 이미지가 로드될 R2 공개 URL (프로덕션 빌드 시 필요).
# 비워두면 로컬 public/media 를 씁니다 (dev).
# NEXT_PUBLIC_MEDIA_BASE_URL=https://pub-xxxx.r2.dev

# --- 이미지를 R2에 업로드할 때만 필요 (npm run upload:r2) ---
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=ws-deckcheck-media

# --- 아래는 로컬에서 수집/AI를 돌릴 때만 필요 ---

# AI 덱 추출 (npm run eval). console.anthropic.com/settings/keys 에서 발급
# ANTHROPIC_API_KEY=sk-ant-...

# 관리자 검수 화면을 프로덕션에서 열려면 (기본은 프로덕션에서 404).
# 진짜 인증(Auth.js 등)을 붙인 뒤에만 true 로.
# ADMIN_AUTH_CONFIGURED=true

# 배포용 서버 Postgres 를 쓸 경우 (기본은 로컬 PGlite).
# DATABASE_URL=postgres://...
