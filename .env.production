# Deck images are served from Cloudflare R2, not from the repo.
#
# This is a public bucket URL, not a secret — it must be committed so the Vercel
# build inlines it (NEXT_PUBLIC_* is baked in at build time). Keeping the ~3GB of
# images out of git and out of the deployment is the whole point: the archive
# grows by thousands of photos, which a git repo cannot absorb.
NEXT_PUBLIC_MEDIA_BASE_URL=https://pub-2ac92abab6a244bd9dfe73f8e5607c88.r2.dev
